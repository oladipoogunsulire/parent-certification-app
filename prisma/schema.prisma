generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ==============================
// IDENTITY & ACCESS
// ==============================

model User {
  id             String    @id @default(uuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  oauthProvider  String?
  oauthId        String?
  firstName      String?
  lastName       String?
  displayName    String?
  role           Role      @default(USER)
  isActive       Boolean   @default(true)
  currentBelt    String?
  beltEarnedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  profile              UserProfile?
  subscriptions        UserSubscription[]
  certifications       Certification[]
  beltExamAttempts     BeltExamAttempt[]
  xpTransactions       XPTransaction[]
  userBadges           UserBadge[]
  ceRecords            CERecord[]
  leadershipStatuses   LeadershipStatus[]
  streak               UserStreak?
  auditLogs            AuditLog[]
  notificationPrefs    NotificationPreference?
  inAppNotifications   InAppNotification[]
  lessonProgress       UserLessonProgress[]
  securityQuestion     UserSecurityQuestion?
  resetTokens          PasswordResetToken[]
  scenarioAttempts     UserScenarioAttempt[]
  influenceProfile     UserInfluenceProfile?
  examAttempts         ExamAttempt[]
  examCertificate      ExamCertificate?
  adminActions         AdminActionLog[] @relation("AdminActions")
  targetActions        AdminActionLog[] @relation("TargetActions")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  USER
  ADMIN
  MODERATOR
  CONTENT_ADMIN
  CERTIFICATION_ADMIN
  ANALYTICS_VIEWER
}

model UserProfile {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  preferredLanguage       String?  @default("en")
  timezone                String?
  ageBandFocus            String?
  notificationPreferences Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

// ==============================
// SUBSCRIPTION & ENTITLEMENT
// ==============================

model SubscriptionPlan {
  id                  String   @id @default(uuid())
  planName            String
  price               Float
  currency            String   @default("USD")
  billingInterval     BillingInterval
  includesBlackBelt   Boolean  @default(false)
  includesLeadership  Boolean  @default(false)
  includesGlobal      Boolean  @default(false)
  isActive            Boolean  @default(true)
  stripePriceId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

model UserSubscription {
  id                String             @id @default(uuid())
  userId            String
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime?
  stripeSubId       String?
  stripeCustomerId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

// ==============================
// CONTENT SYSTEM
// ==============================

model Track {
  id                   String          @id @default(uuid())
  trackName            String
  description          String?
  ageBand              String?
  curriculumVersion    String          @default("1.0")
  expiryDurationMonths Int             @default(12)
  renewalModelType     RenewalModel    @default(EXAM_ONLY)
  isActive             Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  belts          Belt[]
  modules        Module[]
  certifications Certification[]
  questions      Question[]
  ceRecords      CERecord[]

  @@map("tracks")
}

enum RenewalModel {
  EXAM_ONLY
  CE_ONLY
  HYBRID
}

model Belt {
  id               String   @id @default(uuid())
  trackId          String
  beltLevel        String
  orderIndex       Int
  passingThreshold Float    @default(75.0)
  expirable        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  track             Track             @relation(fields: [trackId], references: [id])
  modules           Module[]
  certifications    Certification[]
  beltExamAttempts  BeltExamAttempt[]
  questions         Question[]
  scenarios         Scenario[]

  @@unique([trackId, beltLevel])
  @@map("belts")
}

model Module {
  id            String   @id @default(uuid())
  trackId       String
  beltId        String
  moduleTitle   String
  description   String?
  introVideoUrl String?
  isRequired    Boolean  @default(true)
  xpValue       Int      @default(50)
  ceEligible    Boolean  @default(false)
  ceValue       Float    @default(0)
  orderIndex    Int
  isActive      Boolean  @default(true)
  isFreePreview Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  track     Track      @relation(fields: [trackId], references: [id])
  belt      Belt       @relation(fields: [beltId], references: [id])
  lessons   Lesson[]
  scenarios Scenario[]
  ceRecords CERecord[]

  @@map("modules")
}

model Lesson {
  id                       String   @id @default(uuid())
  moduleId                 String
  lessonTitle              String
  contentBody              String
  reflectionPrompt         String?
  introVideoUrl            String?
  mainVideoUrl             String?
  estimatedDurationMinutes Int?
  xpValue                  Int      @default(20)
  versionNumber            String   @default("1.0")
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  module        Module               @relation(fields: [moduleId], references: [id])
  xpTransactions XPTransaction[]
  userProgress  UserLessonProgress[]
  resources     LessonResource[]

  @@map("lessons")
}

model LessonResource {
  id            String   @id @default(cuid())
  lessonId      String
  fileName      String
  fileKey       String   // R2 object key
  fileSize      Int      // bytes
  mimeType      String
  uploadedAt    DateTime @default(now())
  downloadCount Int      @default(0)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_resources")
}

model UserLessonProgress {
  id            String    @id @default(cuid())
  userId        String
  lessonId      String
  completed     Boolean   @default(false)
  completedAt   DateTime?
  lastVisitedAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model Scenario {
  id                String   @id @default(uuid())
  moduleId          String
  beltId            String
  scenarioTitle     String?
  videoUrl          String?
  narrativeText     String
  complexityLevel   Int      @default(1)
  xpValue           Int      @default(30)
  isRequired        Boolean  @default(true)
  versionNumber     String   @default("1.0")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  module    Module              @relation(fields: [moduleId], references: [id])
  belt      Belt                @relation(fields: [beltId], references: [id])
  responses ScenarioResponse[]
  attempts  UserScenarioAttempt[]

  @@map("scenarios")
}

model ScenarioResponse {
  id              String   @id @default(uuid())
  scenarioId      String
  responseText    String
  isOptimal       Boolean  @default(false)
  scoreImpact     Float    @default(0)
  explanationText String?
  createdAt       DateTime @default(now())

  scenario Scenario             @relation(fields: [scenarioId], references: [id])
  attempts UserScenarioAttempt[]

  @@map("scenario_responses")
}

model Question {
  id              String       @id @default(uuid())
  trackId         String
  beltId          String
  questionText    String
  questionType    QuestionType @default(MULTIPLE_CHOICE)
  difficultyLevel Int          @default(1)
  versionNumber   String       @default("1.0")
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  track   Track            @relation(fields: [trackId], references: [id])
  belt    Belt             @relation(fields: [beltId], references: [id])
  options QuestionOption[]

  @@map("questions")
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  SCENARIO_INTEGRATED
}

model QuestionOption {
  id              String   @id @default(uuid())
  questionId      String
  optionText      String
  isCorrect       Boolean  @default(false)
  explanationText String?
  createdAt       DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id])

  @@map("question_options")
}

// ==============================
// CERTIFICATION ENGINE
// ==============================

model Certification {
  id                      String              @id @default(uuid())
  userId                  String
  trackId                 String
  beltId                  String
  status                  CertificationStatus @default(NOT_STARTED)
  issueDate               DateTime?
  expiryDate              DateTime?
  curriculumVersionAtIssue String?
  verificationToken       String?             @unique
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user   User  @relation(fields: [userId], references: [id])
  track  Track @relation(fields: [trackId], references: [id])
  belt   Belt  @relation(fields: [beltId], references: [id])
  events CertificationEvent[]

  @@unique([userId, trackId, beltId])
  @@map("certifications")
}

enum CertificationStatus {
  NOT_STARTED
  IN_PROGRESS
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

model CertificationEvent {
  id              String   @id @default(uuid())
  certificationId String
  eventType       String
  previousStatus  String?
  newStatus       String
  reasonCode      String?
  performedBy     String?
  timestamp       DateTime @default(now())

  certification Certification @relation(fields: [certificationId], references: [id])

  @@map("certification_events")
}

model BeltExamAttempt {
  id              String   @id @default(uuid())
  userId          String
  trackId         String
  beltId          String
  scorePercentage Float
  passed          Boolean  @default(false)
  attemptNumber   Int
  timeTakenSeconds Int?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  belt Belt @relation(fields: [beltId], references: [id])

  @@map("belt_exam_attempts")
}

// ==============================
// GAMIFICATION
// ==============================

model XPTransaction {
  id         String     @id @default(uuid())
  userId     String
  sourceType XPSource
  sourceId   String
  xpAmount   Int
  createdAt  DateTime   @default(now())

  user   User    @relation(fields: [userId], references: [id])
  lesson Lesson? @relation(fields: [sourceId], references: [id], map: "xp_lesson_fk")

  @@map("xp_transactions")
}

enum XPSource {
  LESSON
  SCENARIO
  EXAM
  STREAK
  CE
}

model UserStreak {
  userId                   String   @id
  currentStreakCount        Int      @default(0)
  longestStreak            Int      @default(0)
  lastQualifyingActivityDate DateTime?
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_streaks")
}

model Badge {
  id           String   @id @default(uuid())
  badgeName    String
  description  String?
  triggerEvent String
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId    String
  badgeId   String
  earnedDate DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("user_badges")
}

// ==============================
// CONTINUING EDUCATION
// ==============================

model CERecord {
  id           String   @id @default(uuid())
  userId       String
  trackId      String
  moduleId     String
  creditsEarned Float
  earnedDate   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  track  Track  @relation(fields: [trackId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@map("ce_records")
}

// ==============================
// LEADERSHIP
// ==============================

model LeadershipStatus {
  id              String   @id @default(uuid())
  userId          String
  trackId         String?
  isActive        Boolean  @default(false)
  activatedDate   DateTime?
  deactivatedDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("leadership_statuses")
}

// ==============================
// AUDIT & GOVERNANCE
// ==============================

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String?
  actorRole     String?
  actionType    String
  entityType    String
  entityId      String
  previousValue Json?
  newValue      Json?
  timestamp     DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

// ==============================
// NOTIFICATIONS
// ==============================

model NotificationPreference {
  userId                   String  @id
  receiveMarketingEmails   Boolean @default(false)
  receiveEngagementEmails  Boolean @default(true)
  receiveInAppNotifications Boolean @default(true)

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

model InAppNotification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("in_app_notifications")
}

model UserSecurityQuestion {
  id          String   @id @default(cuid())
  userId      String   @unique
  question1   String
  answer1Hash String
  question2   String
  answer2Hash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security_questions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ==============================
// INFLUENCE SCORE™ ENGINE
// ==============================

model UserScenarioAttempt {
  id                 String   @id @default(cuid())
  userId             String
  scenarioId         String
  selectedResponseId String
  scoreEarned        Float
  attemptNumber      Int
  completedAt        DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario         Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  selectedResponse ScenarioResponse @relation(fields: [selectedResponseId], references: [id], onDelete: Cascade)

  @@map("user_scenario_attempts")
}

model UserInfluenceProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  influenceScore   Float    @default(0)
  totalAttempts    Int      @default(0)
  totalScorePoints Float    @default(0)
  influenceLevel   String   @default("Reactive Parent")
  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_influence_profiles")
}

// ==============================
// BLACK BELT EXAM ENGINE
// ==============================

enum ExamDifficulty {
  EASY
  MEDIUM
  HARD
}

model ExamConfiguration {
  id                   String   @id @default(cuid())
  isEnabled            Boolean  @default(false)
  passingThreshold     Float    @default(90)      // percentage e.g. 90 = 90%
  totalQuestions       Int      @default(40)      // questions per attempt
  isTimed              Boolean  @default(true)
  timeLimitMinutes     Int      @default(45)
  easyPercent          Int      @default(40)      // % of easy questions
  mediumPercent        Int      @default(40)      // % of medium questions
  hardPercent          Int      @default(20)      // % of hard questions
  randomiseQuestions   Boolean  @default(true)
  randomiseOptions     Boolean  @default(true)
  certificateSignatory String   @default("Dr. Tilis")
  updatedAt            DateTime @updatedAt

  @@map("exam_configuration")
}

model ExamQuestion {
  id           String         @id @default(cuid())
  questionText String         // the question
  difficulty   ExamDifficulty @default(MEDIUM)
  moduleTag    String?        // optional — which module this question relates to
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  options  ExamQuestionOption[]
  attempts ExamAttemptAnswer[]

  @@map("exam_questions")
}

model ExamQuestionOption {
  id           String   @id @default(cuid())
  questionId   String
  optionText   String
  isCorrect    Boolean  @default(false)
  explanation  String?  // shown after answering — why this is right or wrong
  displayOrder Int      @default(0)

  question ExamQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempts ExamAttemptAnswer[]

  @@map("exam_question_options")
}

model ExamAttempt {
  id               String    @id @default(cuid())
  userId           String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  score            Float?    // percentage score e.g. 87.5
  passed           Boolean?  // true if score >= passingThreshold
  attemptNumber    Int       @default(1)
  timeTakenSeconds Int?      // how long the user took

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     ExamAttemptAnswer[]
  certificate ExamCertificate?

  @@map("exam_attempts")
}

model ExamAttemptAnswer {
  id               String   @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean
  answeredAt       DateTime @default(now())

  attempt        ExamAttempt        @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       ExamQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption ExamQuestionOption @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@map("exam_attempt_answers")
}

model ExamCertificate {
  id                String   @id @default(cuid())
  userId            String   @unique
  attemptId         String   @unique
  certificateCode   String   @unique @default(cuid()) // unique verification code
  issuedAt          DateTime @default(now())
  score             Float    // score at time of passing

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("exam_certificates")
}

// ==============================
// ADMIN ACTION LOG
// ==============================

model AdminActionLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String
  action       String   // e.g. "BELT_ADJUSTED", "PROGRESS_RESET", "ACCOUNT_DEACTIVATED"
  detail       String   // human-readable description
  createdAt    DateTime @default(now())

  admin      User @relation("AdminActions",  fields: [adminId],      references: [id])
  targetUser User @relation("TargetActions", fields: [targetUserId], references: [id])

  @@map("admin_action_logs")
}